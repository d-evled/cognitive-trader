# Copy to .env (gitignored) and fill in from your Alpaca PAPER account:
# https://app.alpaca.markets -> Home -> Paper trading -> API Keys
ALPACA_API_KEY=your-paper-key-here
ALPACA_SECRET_KEY=your-paper-secret-here

# For LLM vetting (run_daily --vet, backtest --llm). Get one at
# https://console.anthropic.com -> API Keys. ~$5-15/mo during dev.
ANTHROPIC_API_KEY=your-anthropic-key-here
